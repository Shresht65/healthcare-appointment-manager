# --- Database ---
# Default: local SQLite, zero setup needed. For deployment, use Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# --- LLM (Anthropic Claude) ---
# Leave blank to run in mock mode (app still works, summaries are stubbed)

GEMINI_API_KEY=
LLM_MODEL=gemini-flash-latest
# --- Email (SendGrid) ---
# Leave blank to run in mock mode (emails are logged, not actually sent)
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@example.com

# --- Google Calendar OAuth2 ---
# Leave blank to run in mock mode (fake event IDs are generated)
# See README.md "Google Calendar setup" section for how to obtain these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth2callback

# --- App ---
APP_BASE_URL=http://localhost:8000
